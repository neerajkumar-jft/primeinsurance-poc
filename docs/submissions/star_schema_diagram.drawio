<mxfile host="app.diagrams.net">
  <diagram id="star-schema" name="Star Schema">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="PrimeInsurance Star Schema — primeins.gold" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- dim_customer -->
        <mxCell id="dim_cust" value="dim_customer&#xa;Source: silver.customers&#xa;─────────────────&#xa;PK: customer_id (int)&#xa;─────────────────&#xa;region (string)&#xa;state (string)&#xa;city (string)&#xa;job (string)&#xa;marital (string)&#xa;education (string)&#xa;default_flag (int)&#xa;balance (int)&#xa;hh_insurance (int)&#xa;car_loan (int)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFACD;strokeColor=#DAA520;strokeWidth=2;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="200" height="230" as="geometry"/>
        </mxCell>

        <!-- dim_policy -->
        <mxCell id="dim_pol" value="dim_policy&#xa;Source: silver.policy&#xa;─────────────────&#xa;PK: policy_number (string)&#xa;FK: customer_id → dim_customer&#xa;FK: car_id → dim_car&#xa;─────────────────&#xa;policy_bind_date (date)&#xa;policy_state (string)&#xa;policy_csl (string)&#xa;policy_deductible (int)&#xa;policy_annual_premium (double)&#xa;umbrella_limit (int)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFACD;strokeColor=#DAA520;strokeWidth=2;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="230" height="240" as="geometry"/>
        </mxCell>

        <!-- fact_claims -->
        <mxCell id="fact_claims" value="fact_claims&#xa;Grain: 1 row per claim&#xa;─────────────────────&#xa;PK: claim_id (string)&#xa;FK: policy_number → dim_policy&#xa;─────────────────────&#xa;MEASURES:&#xa;  injury_amount (double)&#xa;  property_amount (double)&#xa;  vehicle_amount (double)&#xa;  total_claim_amount (double)&#xa;  is_rejected (boolean)&#xa;─────────────────────&#xa;incident_date (string)*&#xa;incident_state (string)&#xa;incident_city (string)&#xa;incident_type (string)&#xa;collision_type (string)&#xa;incident_severity (string)&#xa;vehicles_involved (int)&#xa;bodily_injuries (int)&#xa;witnesses (int)&#xa;authorities_contacted (string)&#xa;property_damage (string)&#xa;police_report_available (string)&#xa;claim_logged_on (string)*&#xa;claim_processed_on (string)*&#xa;&#xa;* dates corrupted at source" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E6F0FF;strokeColor=#4A90D9;strokeWidth=2;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="400" y="60" width="250" height="480" as="geometry"/>
        </mxCell>

        <!-- dim_car -->
        <mxCell id="dim_car" value="dim_car&#xa;Source: silver.cars&#xa;─────────────────&#xa;PK: car_id (int)&#xa;─────────────────&#xa;name (string)&#xa;model (string)&#xa;fuel (string)&#xa;transmission (string)&#xa;km_driven (int)&#xa;mileage (double)&#xa;mileage_unit (string)&#xa;engine (int)&#xa;max_power (double)&#xa;torque (string)&#xa;seats (int)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFACD;strokeColor=#DAA520;strokeWidth=2;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="190" height="270" as="geometry"/>
        </mxCell>

        <!-- fact_sales -->
        <mxCell id="fact_sales" value="fact_sales&#xa;Grain: 1 row per car listing&#xa;───────────────────────&#xa;PK: sales_id (int)&#xa;FK: car_id → dim_car&#xa;───────────────────────&#xa;MEASURES:&#xa;  original_selling_price (double)&#xa;  days_listed (int)&#xa;  is_sold (boolean)&#xa;───────────────────────&#xa;ad_placed_on (timestamp)&#xa;sold_on (timestamp)&#xa;region (string)&#xa;state (string)&#xa;city (string)&#xa;seller_type (string)&#xa;owner (string)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E6F0FF;strokeColor=#4A90D9;strokeWidth=2;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="780" y="410" width="240" height="340" as="geometry"/>
        </mxCell>

        <!-- dim_region -->
        <mxCell id="dim_region" value="dim_region&#xa;Source: hardcoded&#xa;───────────────&#xa;PK: region (string)&#xa;───────────────&#xa;region_code (string)&#xa;&#xa;5 rows: East(E),&#xa;West(W), Central(C),&#xa;South(S), North(N)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFACD;strokeColor=#DAA520;strokeWidth=2;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1100" y="80" width="170" height="180" as="geometry"/>
        </mxCell>

        <!-- RELATIONSHIPS -->

        <!-- fact_claims -> dim_policy (policy_number) -->
        <mxCell id="rel1" value="policy_number" style="endArrow=ERone;startArrow=ERmany;endFill=0;startFill=0;strokeWidth=2;strokeColor=#333333;fontSize=10;" edge="1" parent="1" source="fact_claims" target="dim_pol">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- dim_policy -> dim_customer (customer_id) -->
        <mxCell id="rel2" value="customer_id" style="endArrow=ERone;startArrow=ERmany;endFill=0;startFill=0;strokeWidth=2;strokeColor=#333333;fontSize=10;" edge="1" parent="1" source="dim_pol" target="dim_cust">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- dim_policy -> dim_car (car_id) -->
        <mxCell id="rel3" value="car_id" style="endArrow=ERone;startArrow=ERmany;endFill=0;startFill=0;strokeWidth=2;strokeColor=#333333;fontSize=10;" edge="1" parent="1" source="dim_pol" target="dim_car">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- fact_sales -> dim_car (car_id) -->
        <mxCell id="rel4" value="car_id" style="endArrow=ERone;startArrow=ERmany;endFill=0;startFill=0;strokeWidth=2;strokeColor=#333333;fontSize=10;" edge="1" parent="1" source="fact_sales" target="dim_car">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Business questions box -->
        <mxCell id="biz_q" value="How this model answers PrimeInsurance's 3 business failures:&#xa;&#xa;1. Regulatory pressure (customer identity):&#xa;   dim_customer is deduplicated. SELECT region, COUNT(DISTINCT customer_id)&#xa;   FROM dim_customer GROUP BY region → auditable count&#xa;&#xa;2. Claims backlog:&#xa;   fact_claims JOIN dim_policy → rejection rate by policy_csl and region.&#xa;   fact_claims GROUP BY incident_severity → claim volume and value by severity.&#xa;   Note: processing time in days blocked by corrupted date fields.&#xa;&#xa;3. Revenue leakage (unsold inventory):&#xa;   fact_sales JOIN dim_car WHERE is_sold = false → unsold cars by model,&#xa;   region, with days_listed for aging analysis." style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F0F0F0;strokeColor=#999999;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="340" width="300" height="260" as="geometry"/>
        </mxCell>

        <!-- Join paths box -->
        <mxCell id="joins" value="Join paths:&#xa;&#xa;Claims → Policy type:&#xa;  fact_claims → dim_policy (policy_number)&#xa;&#xa;Claims → Customer region:&#xa;  fact_claims → dim_policy (policy_number)&#xa;  → dim_customer (customer_id)&#xa;&#xa;Claims → Car:&#xa;  fact_claims → dim_policy (policy_number)&#xa;  → dim_car (car_id via dim_policy)&#xa;&#xa;Sales → Car model:&#xa;  fact_sales → dim_car (car_id)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF8F0;strokeColor=#DAA520;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="620" width="300" height="200" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
