        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#e91e63;strokeWidth=2;" edge="1" parent="1" source="in_quarantine" target="ai_box">
          <mxGeometry relative="1" as="geometry"/>
