  <diagram id="genai" name="GenAI Integration">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="PrimeInsurance — GenAI Integration" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=22;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="700" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Where AI sits, what goes in, what comes out" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="400" y="50" width="500" height="20" as="geometry"/>
        </mxCell>

        <!-- Input Sources (Left Side) -->
        <mxCell id="input_label" value="DATA INPUTS" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontStyle=1;fontColor=#999;letterSpacing=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="200" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="in_gold" value="&lt;b&gt;Gold Layer Tables&lt;/b&gt;&lt;br&gt;&lt;br&gt;dim_customers (is_duplicate, source_count)&lt;br&gt;dim_policies&lt;br&gt;dim_cars&lt;br&gt;fact_claims (days_to_process, is_rejected)&lt;br&gt;fact_sales (days_to_sell, is_aging)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffc107;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="260" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="in_views" value="&lt;b&gt;Gold Views&lt;/b&gt;&lt;br&gt;&lt;br&gt;vw_customer_360&lt;br&gt;vw_claims_processing&lt;br&gt;vw_aging_inventory&lt;br&gt;vw_revenue_leakage&lt;br&gt;vw_regulatory_customer_count" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffc107;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="270" width="260" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="in_quarantine" value="&lt;b&gt;Silver Quarantine Tables&lt;/b&gt;&lt;br&gt;(exception: AI reaches into Silver)&lt;br&gt;&lt;br&gt;quarantine_customers&lt;br&gt;quarantine_claims&lt;br&gt;quarantine_sales" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e91e63;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="260" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="in_eventlog" value="&lt;b&gt;DLT Event Log&lt;/b&gt;&lt;br&gt;Pass/fail counts, rule names, timestamps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#607d8b;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="260" height="50" as="geometry"/>
        </mxCell>

        <!-- GenAI Engine (Center) -->
        <mxCell id="ai_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="380" y="100" width="340" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="ai_title" value="GenAI Intelligence Layer" style="text;html=1;strokeColor=none;fillColor=#2e7d32;fontColor=#ffffff;align=center;fontSize=14;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="110" width="280" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="uc1" value="&lt;b&gt;1. Data Quality Explanations&lt;/b&gt;&lt;br&gt;&lt;br&gt;Reads quarantine + event log&lt;br&gt;Produces plain English reports&lt;br&gt;&lt;br&gt;&lt;i&gt;&quot;47 records from East quarantined:&lt;br&gt;CustomerID was null. 2.3% of batch.&quot;&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#a5d6a7;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="400" y="155" width="300" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="uc2" value="&lt;b&gt;2. Anomalous Claims Investigation&lt;/b&gt;&lt;br&gt;&lt;br&gt;Reads fact_claims + dim_policies&lt;br&gt;Flags claims 3x above avg processing time&lt;br&gt;&lt;br&gt;&lt;i&gt;&quot;Avg processing: 18 days. Top bottleneck:&lt;br&gt;claims needing cross-system lookup.&quot;&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#a5d6a7;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="400" y="280" width="300" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="uc3" value="&lt;b&gt;3. Natural Language Querying (AI/BI)&lt;/b&gt;&lt;br&gt;&lt;br&gt;User types question in plain English&lt;br&gt;AI generates SQL against Gold schema&lt;br&gt;Returns results + explanation&lt;br&gt;&lt;br&gt;&lt;i&gt;&quot;Show me Premium policies in Ohio&quot;&lt;br&gt;→ SELECT * FROM gold.dim_policies...&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#a5d6a7;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="400" y="405" width="300" height="120" as="geometry"/>
        </mxCell>

        <!-- Tech Stack inside AI box -->
        <mxCell id="tech" value="Foundation Model APIs (DBRX/Llama/GPT-4) | Vector Search | Schema Comments" style="text;html=1;strokeColor=none;fillColor=#c8e6c9;align=center;fontSize=9;rounded=1;fontColor=#1b5e20;" vertex="1" parent="1">
          <mxGeometry x="400" y="540" width="300" height="25" as="geometry"/>
        </mxCell>

        <!-- Arrows: inputs to AI -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#ffc107;strokeWidth=2;" edge="1" parent="1" source="in_gold" target="ai_box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#ffc107;strokeWidth=2;" edge="1" parent="1" source="in_views" target="ai_box">
          <mxGeometry relative="1" as="geometry"/>
