        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#607d8b;strokeWidth=2;" edge="1" parent="1" source="in_eventlog" target="ai_box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Output Side (Right) -->
        <mxCell id="output_label" value="OUTPUTS" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontStyle=1;fontColor=#999;letterSpacing=2;" vertex="1" parent="1">
          <mxGeometry x="810" y="90" width="200" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="out1" value="&lt;b&gt;gold.ai_quality_reports&lt;/b&gt;&lt;br&gt;&lt;br&gt;Plain English quality summaries&lt;br&gt;Queryable via dashboards&lt;br&gt;Compliance team consumes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="800" y="120" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="out2" value="&lt;b&gt;gold.ai_claims_alerts&lt;/b&gt;&lt;br&gt;&lt;br&gt;Flagged anomalous claims&lt;br&gt;Investigation briefs&lt;br&gt;Ops team / adjusters consume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="800" y="240" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="out3" value="&lt;b&gt;AI/BI Interface (direct)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Results returned in the UI&lt;br&gt;where user typed question.&lt;br&gt;Not persisted to a table.&lt;br&gt;Execs &amp; analysts consume." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#2196f3;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="800" y="360" width="240" height="110" as="geometry"/>
        </mxCell>

        <!-- Arrows: AI to outputs -->
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#4caf50;strokeWidth=2;" edge="1" parent="1" source="uc1" target="out1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#4caf50;strokeWidth=2;" edge="1" parent="1" source="uc2" target="out2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2196f3;strokeWidth=2;" edge="1" parent="1" source="uc3" target="out3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Guardrail -->
        <mxCell id="guardrail" value="&lt;b&gt;GUARDRAIL:&lt;/b&gt; Every AI response includes the SQL query used. Users can read and verify the query themselves. No black box numbers in regulatory filings." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;strokeWidth=2;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="660" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- Why Gold box -->
        <mxCell id="why_gold" value="&lt;b&gt;Why above Gold, not Silver or Bronze?&lt;/b&gt;&lt;br&gt;&lt;br&gt;Bronze: 3 different ID column names, corrupted dates, &quot;?&quot; values → AI-generated SQL breaks&lt;br&gt;Silver: No business measures (no days_to_process, no aging_bucket) → business logic in prompts&lt;br&gt;Gold: Star schema, pre-computed measures, descriptive names → AI generates correct SQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9c27b0;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="300" y="720" width="600" height="90" as="geometry"/>
        </mxCell>

