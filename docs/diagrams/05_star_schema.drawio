        <mxCell id="fc_body" value="claim_id  INT  (degenerate dim)&#xa;policy_key  INT  (FK → dim_policies)&#xa;customer_key  INT  (FK → dim_customers)&#xa;car_key  INT  (FK → dim_cars)&#xa;incident_date_key  INT  (FK → dim_date)&#xa;logged_date_key  INT  (FK → dim_date)&#xa;───── measures ─────&#xa;injury  DOUBLE&#xa;property_amount  DOUBLE&#xa;vehicle  DOUBLE&#xa;total_claim_amount  DOUBLE&#xa;days_to_process  INT&#xa;is_rejected  BOOLEAN&#xa;───── degenerate dims ─────&#xa;incident_type  STRING&#xa;incident_severity  STRING&#xa;collision_type  STRING&#xa;incident_state  STRING&#xa;incident_city  STRING" style="text;html=0;whiteSpace=wrap;fillColor=#FFE6E6;strokeColor=#B85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
