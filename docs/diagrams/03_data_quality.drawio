<mxfile host="app.diagrams.net" modified="2026-03-23T12:00:00.000Z" agent="5.0" etag="primeins-quality" version="21.0.0" type="device">
  <diagram id="quality" name="Data Quality Strategy">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="PrimeInsurance — Data Quality Strategy" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=22;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="700" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="What checks happen at which layer, and what happens when records fail" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="350" y="50" width="600" height="20" as="geometry"/>
        </mxCell>

        <!-- Bronze Layer Box -->
        <mxCell id="bronze_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8f0;strokeColor=#ff9800;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="380" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="bronze_title" value="BRONZE — Structural Checks Only" style="text;html=1;strokeColor=none;fillColor=#ff9800;fontColor=#ffffff;align=center;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="300" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="b_check1" value="&lt;b&gt;Schema enforcement&lt;/b&gt; (Auto Loader)&lt;br&gt;Unparseable records → _rescued_data column&lt;br&gt;&lt;font color=&quot;#e65100&quot;&gt;Action: RESCUE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffcc80;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="340" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="b_check2" value="&lt;b&gt;Source file tracking&lt;/b&gt;&lt;br&gt;Every record stamped with _source_file + _ingestion_timestamp&lt;br&gt;&lt;font color=&quot;#2e7d32&quot;&gt;Action: ALWAYS ON&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffcc80;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="195" width="340" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="b_check3" value="&lt;b&gt;Rescued data check&lt;/b&gt; — EXPECT(_rescued_data IS NULL) ON VIOLATION FAIL UPDATE&lt;br&gt;If schema is completely broken, &lt;font color=&quot;#b71c1c&quot;&gt;HALT the pipeline&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffcc80;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="340" height="45" as="geometry"/>
        </mxCell>

        <!-- Arrow Bronze to Silver -->
        <mxCell id="arrow_bs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;strokeColor=#5c6bc0;" edge="1" parent="1" source="bronze_box" target="silver_box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_bs_label" value="DLT Expectations&lt;br&gt;fire here" style="edgeLabel;html=1;align=center;fontSize=10;fontStyle=1;fontColor=#5c6bc0;" vertex="1" connectable="0" parent="arrow_bs">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Silver Layer Box -->
        <mxCell id="silver_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f1fa;strokeColor=#5c6bc0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="380" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="silver_title" value="SILVER — Business Rules Enforced" style="text;html=1;strokeColor=none;fillColor=#283593;fontColor=#ffffff;align=center;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="300" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="s_check1" value="&lt;b&gt;NOT NULL on key fields&lt;/b&gt; — customer_id, claim_id, policy_number, sales_id, car_id&lt;br&gt;EXPECT (customer_id IS NOT NULL) ON VIOLATION DROP ROW&lt;br&gt;&lt;font color=&quot;#c62828&quot;&gt;Action: QUARANTINE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c5cae9;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="405" width="340" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="s_check2" value="&lt;b&gt;Valid value ranges&lt;/b&gt; — Region in (East, West, Central, South, North)&lt;br&gt;Education in (primary, secondary, tertiary). After harmonization (W→West, terto→tertiary)&lt;br&gt;&lt;font color=&quot;#c62828&quot;&gt;Action: QUARANTINE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c5cae9;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="470" width="340" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="s_check3" value="&lt;b&gt;Soft referential integrity&lt;/b&gt; — policy.customer_id exists in customers_unified?&lt;br&gt;EXPECT only (warn). Record passes through.&lt;br&gt;&lt;font color=&quot;#f57f17&quot;&gt;Action: WARN + LOG&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c5cae9;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="535" width="340" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s_check4" value="&lt;b&gt;Deduplication&lt;/b&gt; — customers_1 &amp; customers_7 share IDs (100006, 100013...)&lt;br&gt;ROW_NUMBER keeps most complete record. Resolves 12% inflation.&lt;br&gt;&lt;font color=&quot;#2e7d32&quot;&gt;Action: DEDUP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c5cae9;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="595" width="340" height="50" as="geometry"/>
        </mxCell>

        <!-- Quarantine Box -->
        <mxCell id="quarantine_box" value="&lt;b&gt;QUARANTINE TABLES&lt;/b&gt;&lt;br&gt;&lt;br&gt;quarantine_customers&lt;br&gt;quarantine_claims&lt;br&gt;quarantine_sales&lt;br&gt;&lt;br&gt;Each record keeps:&lt;br&gt;• Original data (unchanged)&lt;br&gt;• Quarantine reason&lt;br&gt;• Timestamp&lt;br&gt;• _source_file from Bronze" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e91e63;strokeWidth=2;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="360" width="220" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_sq" value="Failed records" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#e91e63;strokeWidth=2;fontSize=10;fontColor=#e91e63;" edge="1" parent="1" source="silver_box" target="quarantine_box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- GenAI explains -->
        <mxCell id="genai_explain" value="&lt;b&gt;GenAI explains in&lt;br&gt;plain English&lt;/b&gt;&lt;br&gt;&lt;br&gt;&quot;47 records from East&lt;br&gt;quarantined: CustomerID&lt;br&gt;was null. 2.3% of batch.&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="570" width="220" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_qg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#4caf50;strokeWidth=1;" edge="1" parent="1" source="quarantine_box" target="genai_explain">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Gold Layer Box -->
        <mxCell id="gold_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffef0;strokeColor=#ffc107;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="380" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="gold_title" value="GOLD — Referential Integrity" style="text;html=1;strokeColor=none;fillColor=#f57f17;fontColor=#ffffff;align=center;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="700" width="300" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="g_check1" value="&lt;b&gt;Hard referential integrity&lt;/b&gt; — fact_claims must have valid customer_key, policy_key&lt;br&gt;Orphaned facts dropped. EXPECT (customer_key IS NOT NULL) ON VIOLATION DROP ROW&lt;br&gt;&lt;font color=&quot;#b71c1c&quot;&gt;Action: DROP ORPHANS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fff9c4;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="735" width="340" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="g_check2" value="&lt;b&gt;Aggregation validation&lt;/b&gt; — Claim amounts not negative, days_to_process &lt; 365&lt;br&gt;Warn only. Record passes, violation logged.&lt;br&gt;&lt;font color=&quot;#f57f17&quot;&gt;Action: WARN + LOG&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fff9c4;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="795" width="340" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="arrow_sg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;strokeColor=#ffc107;" edge="1" parent="1" source="silver_box" target="gold_box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DLT Behavior Legend -->
        <mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#ccc;" vertex="1" parent="1">
          <mxGeometry x="500" y="700" width="380" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="legend_title" value="DLT Expectation Behaviors" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontStyle=1;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="560" y="710" width="260" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="&lt;b&gt;EXPECT (cond)&lt;/b&gt; → Record passes. Violation logged. &lt;font color=&quot;#f57f17&quot;&gt;WARN&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="740" width="350" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="&lt;b&gt;EXPECT (cond) ON VIOLATION DROP ROW&lt;/b&gt; → Removed + quarantined. &lt;font color=&quot;#c62828&quot;&gt;DROP&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="765" width="380" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="&lt;b&gt;EXPECT (cond) ON VIOLATION FAIL UPDATE&lt;/b&gt; → Pipeline halts. &lt;font color=&quot;#b71c1c&quot;&gt;HALT&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="790" width="370" height="20" as="geometry"/>
        </mxCell>

        <!-- Event Log -->
        <mxCell id="eventlog" value="&lt;b&gt;DLT Event Log&lt;/b&gt;&lt;br&gt;(Automatic Audit Trail)&lt;br&gt;&lt;br&gt;Pass/fail counts per rule&lt;br&gt;Timestamps&lt;br&gt;Compliance metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#607d8b;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="790" y="400" width="180" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_se" value="All violations logged" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#607d8b;fontSize=9;fontColor=#607d8b;" edge="1" parent="1" source="silver_box" target="eventlog">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
