          </mxGeometry>
        </mxCell>
        <mxCell id="ai_why_gold" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF0F0;strokeColor=#1E3A5F;align=left;spacingLeft=10;dashed=1;" value="Why does the AI layer sit above Gold?&#xa;&#xa;1. Gold data is clean, joined, and governed. Better input = better LLM output.&#xa;2. Debugging: if AI reads from Gold and produces wrong output, the data already&#xa;   passed validation. The problem is the prompt or model, not the data.&#xa;3. Exception: UC1 reads from silver.dq_issues (quality problems logged during Silver processing)&#xa;4. All AI outputs write to Gold because they are finished, business-ready artifacts." vertex="1">
          <mxGeometry height="130" width="350" x="680" y="440" as="geometry" />
        </mxCell>
        <mxCell id="ai_access" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E8FFE8;strokeColor=#2E8B57;align=left;spacingLeft=10;dashed=1;" value="Business users access AI outputs via SQL Warehouse:&#xa;- DQ explanations → compliance dashboard&#xa;- Anomaly briefs → claims review dashboard (filtered by priority)&#xa;- RAG → notebook-based assistant&#xa;- Executive insights → summary dashboard&#xa;- Genie → natural language queries in Databricks UI" vertex="1">
          <mxGeometry height="110" width="350" x="680" y="590" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
