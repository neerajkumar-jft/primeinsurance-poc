        <mxCell id="ai_uc2_in" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#4A90D9;align=left;spacingLeft=5;" value="INPUT&#xa;primeins.silver.claims&#xa;&#xa;All claim fields: amounts,&#xa;severity, incident type,&#xa;rejection status, policy_id" vertex="1">
