        <mxCell id="dq_s_title" value="SILVER — All quality enforcement (DLT Expectations)" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="495" y="65" width="470" height="25" as="geometry" />
        </mxCell>
        <!-- Three severity levels -->
        <mxCell id="dq_s_drop" value="expect_or_drop&#xa;Bad record removed from clean output.&#xa;Pipeline continues. Record → quarantine table.&#xa;Used for: null customer_id, invalid region,&#xa;out-of-range amounts" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFACD;strokeColor=#DAA520;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="100" width="230" height="85" as="geometry" />
        </mxCell>
        <mxCell id="dq_s_fail" value="expect_or_fail&#xa;Pipeline stops entirely.&#xa;Used for: empty source file,&#xa;completely missing required table" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFE4E1;strokeColor=#CC0000;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="100" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="dq_s_warn" value="expect&#xa;Warning logged, record passes through.&#xa;Used for: missing optional fields&#xa;(education, job title)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E8FFE8;strokeColor=#2E8B57;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="195" width="230" height="75" as="geometry" />
        </mxCell>
        <!-- Rules by entity -->
        <mxCell id="dq_s_rules_title" value="Quality rules by entity:" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="500" y="285" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="dq_s_r_cust" value="customers&#xa;- customer_id NOT NULL&#xa;- region IN (East, West, Central, South, North)&#xa;- No exact duplicate records" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#F5F5F5;strokeColor=#808080;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="500" y="310" width="225" height="60" as="geometry" />
        </mxCell>
        <mxCell id="dq_s_r_claims" value="claims&#xa;- ClaimID NOT NULL, PolicyID NOT NULL&#xa;- amounts (injury, property, vehicle) &gt;= 0&#xa;- Claim_Rejected IN (Y, N)&#xa;- Dates repaired from corrupted format" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#F5F5F5;strokeColor=#808080;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="735" y="310" width="225" height="70" as="geometry" />
        </mxCell>
        <mxCell id="dq_s_r_policy" value="policy&#xa;- policy_number NOT NULL&#xa;- customer_id NOT NULL&#xa;- policy_annual_premium &gt; 0&#xa;- policy_csl valid coverage tier" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#F5F5F5;strokeColor=#808080;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="500" y="380" width="225" height="65" as="geometry" />
        </mxCell>
        <mxCell id="dq_s_r_sales" value="sales&#xa;- sales_id NOT NULL&#xa;- original_selling_price &gt; 0&#xa;- ad_placed_on valid date" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#F5F5F5;strokeColor=#808080;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="735" y="390" width="225" height="55" as="geometry" />
        </mxCell>
        <mxCell id="dq_s_r_cars" value="cars&#xa;- car_id NOT NULL&#xa;- km_driven &gt;= 0" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#F5F5F5;strokeColor=#808080;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="500" y="455" width="225" height="45" as="geometry" />
        </mxCell>
        <!-- Outputs -->
        <mxCell id="dq_s_out_title" value="Quality outputs:" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="500" y="515" width="150" height="20" as="geometry" />
        </mxCell>
        <mxCell id="dq_s_out1" value="dq_issues table — logs every violation with table, column, rule, severity, count" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFE4E1;strokeColor=#CC0000;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="500" y="540" width="460" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dq_s_out2" value="quarantine_* tables — full failed records preserved for compliance team" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFE4E1;strokeColor=#CC0000;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="500" y="570" width="460" height="25" as="geometry" />
