{
  "name": "Prime Insurance - POC",
  "max_concurrent_runs": 1,
  "queue": {"enabled": true},
  "git_source": {
    "git_url": "https://github.com/neerajkumar-jft/primeinsurance-poc.git",
    "git_provider": "gitHub",
    "git_branch": "main"
  },
  "tasks": [
    {
