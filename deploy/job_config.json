        {"task_key": "gold_facts"},
        {"task_key": "uc1_dq_explanations"},
        {"task_key": "uc2_anomaly_engine"},
        {"task_key": "uc3_policy_rag"},
        {"task_key": "uc4_executive_insights"}
      ],
      "notebook_task": {"notebook_path": "notebooks/05_dashboard", "source": "GIT"},
      "timeout_seconds": 600
