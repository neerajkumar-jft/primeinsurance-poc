      "timeout_seconds": 900
    },
    {
      "task_key": "silver_claims",
      "depends_on": [{"task_key": "bronze_ingestion"}],
      "notebook_task": {"notebook_path": "notebooks/02_silver_claims", "source": "GIT"},
      "timeout_seconds": 900
    },
    {
      "task_key": "silver_policy",
      "depends_on": [{"task_key": "bronze_ingestion"}],
      "notebook_task": {"notebook_path": "notebooks/02_silver_policy", "source": "GIT"},
